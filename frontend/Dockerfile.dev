# ---------- Development Dockerfile ----------
# Run with source code mounted as a volume for hot-reload:
#   docker compose -f docker-compose.dev.yml up
FROM node:20-alpine
WORKDIR /app

# Pre-install dependencies (cached unless package.json changes)
COPY package.json package-lock.json* ./
RUN npm install

# Source code will be mounted as a volume — not copied
EXPOSE 5173

CMD ["npm", "run", "dev"]
